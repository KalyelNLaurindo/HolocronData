# ==============================================================================
# Node.js / Vite — .gitignore
# ==============================================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Production build output
dist/
build/

# Vite cache
.vite/

# Environment variables (NEVER commit secrets)
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor directories and files
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# TypeScript (for future migration)
*.tsbuildinfo
